{
  "name": "chrome-tab-recorder",
  "version": "1.4.0",
  "description": "Google Chrome Extensions Screen Recorder",
  "scripts": {
    "build": "webpack --mode=production",
    "build:prod": "ENV_NAME=production webpack --mode=production && rm extension.zip && zip -r extension.zip extension",
    "watch": "webpack --mode=development -w",
    "lint": "eslint {src,*.{mjs,ts}}",
    "test": "jest",
    "site": "serve -p 8080 docs/dist",
    "site:build": "webpack --config docs/webpack.config.ts --mode=production"
  },
  "repository": {
    "type": "git",
    "url": "github.com/ww24/chrome-tab-recorder"
  },
  "homepage": "https://recorder.appcloud.info/",
  "author": "ww24",
  "license": "MIT",
  "dependencies": {
    "@material/web": "^2.4.1",
    "@sentry/browser": "^10.43.0",
    "@mediabunny/flac-encoder": "^1.39.2",
    "lit": "^3.3.2",
    "mediabunny": "^1.38.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "@types/dom-mediacapture-transform": "^0.1.11",
    "@types/dotenv-webpack": "^7.0.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/webpack": "^5.28.5",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "copy-webpack-plugin": "^14.0.0",
    "dotenv-webpack": "^8.1.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^30.3.0",
    "marked": "^17.0.4",
    "serve": "^14.2.6",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  },
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  }
}
